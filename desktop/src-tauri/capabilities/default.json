{
  "identifier": "default",
  "description": "Default capability set for FoundrAI desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "dialog:default",
    "notification:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "foundrai-server",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "foundrai-server",
          "sidecar": true
        }
      ]
    }
  ]
}
