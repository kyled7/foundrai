{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "FoundrAI",
  "version": "0.6.1",
  "identifier": "com.foundrai.desktop",
  "build": {
    "frontendDist": "../../foundrai/frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "FoundrAI",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "visible": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "externalBin": [
      "foundrai-server"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
