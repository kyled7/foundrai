# FoundrAI Environment Variables
# Copy this to .env and fill in your values.

# LLM API Keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Additional LLM providers (via LiteLLM)
# TOGETHER_API_KEY=
# GROQ_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: Override default models per role
# FOUNDRAI_PM_MODEL=anthropic/claude-sonnet-4-20250514
# FOUNDRAI_ARCHITECT_MODEL=anthropic/claude-sonnet-4-20250514
# FOUNDRAI_DEVELOPER_MODEL=openai/gpt-4o
# FOUNDRAI_QA_MODEL=openai/gpt-4o-mini

# Optional: Server configuration
# FOUNDRAI_HOST=0.0.0.0
# FOUNDRAI_PORT=8420

# Optional: Database (defaults to SQLite)
# DATABASE_URL=postgresql://user:pass@localhost:5432/foundrai

# Optional: E2B sandbox (alternative to Docker)
# E2B_API_KEY=
